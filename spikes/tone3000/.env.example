# TONE3000 spike — copy to `.env` and fill in to run for real.
# All values are OPTIONAL: with none set, the spikes run in STUB mode
# (they print exactly what they'd do and exit cleanly).

# Publishable key from your TONE3000 account (client-safe → used as client_id).
# This is what the PKCE flow needs. Do NOT put the SECRET key (t3k_cs_…) here —
# the PKCE flow never uses it.
T3K_CLIENT_ID=pk_your_publishable_key

# Optional: skip the login and use a token you already captured.
# T3K_ACCESS_TOKEN=...

# Optional: an A2 tone id to fetch (makes fetch-a2-model.ts deterministic).
# T3K_TONE_ID=12345

# Optional overrides (defaults shown):
# T3K_CALLBACK_PORT=47700
